<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DJ's Estimate Review</title>
  <style>
    :root{
      --bg:#090a0d;
      --panel:rgba(19,22,29,.98);
      --panel-2:#141922;
      --panel-3:#10141b;
      --text:#f3f4f6;
      --muted:#a1a1aa;
      --line:#2c2f36;
      --line-soft:rgba(255,255,255,.08);
      --accent:#d4af37;
      --accent-soft:rgba(212,175,55,.18);
      --green:#86efac;
      --green-bg:#16351f;
      --yellow:#fde68a;
      --yellow-bg:#3b2a11;
      --red:#fca5a5;
      --red-bg:#3a1818;
      --blue:#3b82f6;
      --card-shadow:0 18px 40px rgba(0,0,0,.30);
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:Arial,Helvetica,sans-serif;
      color:var(--text);
      line-height:1.45;
      background:
        radial-gradient(circle at top left, rgba(212,175,55,.07), transparent 22%),
        radial-gradient(circle at top right, rgba(59,130,246,.07), transparent 20%),
        linear-gradient(180deg, #0d1016 0%, #090a0d 58%, #06070a 100%);
    }
    .wrap{max-width:1140px;margin:0 auto;padding:22px 14px 42px}
    .card{
      background:linear-gradient(180deg, rgba(20,24,33,.98), rgba(14,17,24,.98));
      border:1px solid var(--line-soft);
      border-radius:22px;
      padding:20px;
      margin-bottom:16px;
      box-shadow:var(--card-shadow);
    }
    h1,h2,h3,h4,p{margin:0}
    h1{font-size:30px;line-height:1.05}
    h2{font-size:20px;color:var(--accent)}
    h3{font-size:19px}
    h4{font-size:14px}
    .muted{color:var(--muted)}
    .brandline{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:flex-start}
    .brandbox{display:flex;gap:14px;align-items:center;flex-wrap:wrap}
    .logo{
      width:64px;height:64px;object-fit:contain;border-radius:16px;background:#11151d;
      border:1px solid rgba(255,255,255,.08);padding:8px;box-shadow:inset 0 1px 0 rgba(255,255,255,.03)
    }
    .kicker{
      display:inline-flex;align-items:center;gap:8px;padding:7px 11px;border-radius:999px;
      background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);
      font-size:11px;font-weight:900;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:10px
    }
    .status-box{display:flex;flex-direction:column;gap:10px;align-items:flex-end}
    .pill{
      display:inline-flex;align-items:center;gap:6px;padding:7px 11px;border-radius:999px;font-size:12px;
      border:1px solid rgba(255,255,255,.08);background:#11151d;color:var(--muted);font-weight:800;
      text-transform:uppercase;letter-spacing:.03em
    }
    .approved-pill{color:#052e16;background:var(--green);border-color:var(--green)}
    .warning-pill{color:#3a2a00;background:var(--yellow);border-color:var(--yellow)}
    .meta{
      display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
      gap:10px;margin-top:14px
    }
    .meta div{
      background:linear-gradient(180deg, #121722, #0f131b);
      border:1px solid rgba(255,255,255,.08);
      border-radius:14px;padding:12px;min-height:74px;
      box-shadow:inset 0 1px 0 rgba(255,255,255,.03)
    }
    .actions{display:flex;flex-wrap:wrap;gap:10px;margin-top:16px}
    .no-print{display:flex}
 @media print{

  body{
    background:#ffffff !important;
    color:#111 !important;
  }

  .card,
  .service-card,
  .parts-box,
  .detail-box,
  .meta div,
  .inspection-item{
    background:#ffffff !important;
    color:#111 !important;
    border:1px solid #d1d5db !important;
    box-shadow:none !important;
  }

  h1{color:#111 !important;}
  h2{
    color:#111 !important;
    border-bottom:2px solid #e5e7eb;
    padding-bottom:6px;
  }

  .kicker,
  .pill,
  .muted{
    color:#555 !important;
  }

  .logo{
    background:transparent !important;
    border:none !important;
  }

  .service-title{color:#111 !important;}
  .service-money{
    color:#000 !important;
    font-size:20px !important;
  }

  .parts-box{
    background:#f9fafb !important;
  }

  .part-row{
    border-bottom:1px solid #e5e7eb !important;
  }

  .selected-summary{
    background:#f3f4f6 !important;
    border:1px solid #e5e7eb !important;
  }

  .selected-summary .value{color:#111 !important;}
  .selected-summary .price{
    color:#000 !important;
    font-size:18px !important;
  }

  .choice-card{
    background:#ffffff !important;
    border:1px solid #d1d5db !important;
    box-shadow:none !important;
  }

  .choice-card.selected{
    border:2px solid #000 !important;
    background:#f9fafb !important;
  }

  .choice-name{color:#111 !important;}
  .choice-price{color:#000 !important;}

  .choice-tag{
    background:#e5e7eb !important;
    color:#333 !important;
  }

  .choice-note,
  .mini{
    color:#666 !important;
  }

  .locked-choice{
    background:#f3f4f6 !important;
    border:1px solid #d1d5db !important;
  }

  .locked-tier{color:#111 !important;}
  .locked-price{color:#000 !important;}

  .summary{
    background:#ffffff !important;
    border:2px solid #000 !important;
  }

  .summary-row{
    border-bottom:1px solid #e5e7eb !important;
  }

  .summary-row.total{
    color:#000 !important;
    font-size:22px !important;
  }

  .actions,
  .no-print,
  .btn,
  .signature-wrap,
  canvas,
  input,
  button{
    display:none !important;
  }

}
</style>
</head>
<body>

<!-- KEEP YOUR ORIGINAL BODY CONTENT EXACTLY THE SAME -->

</body>
</html>

  <div class="wrap">
    <div class="card">
      <div class="brandline">
        <div class="brandbox">
          <img src="/static/logo.png" alt="DJ's Mobile Mechanic logo" class="logo" onerror="this.style.display='none'">
          <div>
            <div class="kicker">Estimate Review</div>
            <h1>DJ's Estimate Review</h1>
            <div class="muted">Review the estimate below, choose any available parts option, and approve the services you want completed.</div>
          </div>
        </div>
        <div class="status-box">
          <span class="pill">{{ quote.status or 'quote' }}</span>
          {% if quote.status in ['approved', 'invoiced'] %}
            <span class="pill approved-pill">Locked estimate</span>
          {% else %}
            <span class="pill">Live quote link</span>
          {% endif %}
        </div>
      </div>

      <div class="meta">
        <div><strong>Customer</strong><br>{{ quote.customer_name or '-' }}</div>
        <div><strong>Email</strong><br>{{ quote.customer_email or '-' }}</div>
        <div><strong>Phone</strong><br>{{ quote.customer_phone or '-' }}</div>
        <div><strong>Vehicle</strong><br>{{ quote.vehicle or '-' }}</div>
        <div><strong>VIN</strong><br>{{ quote.vin or '-' }}</div>
        <div><strong>Status</strong><br>{{ quote.status or '-' }}</div>
        <div><strong>Created</strong><br>{{ quote.created_at or '-' }}</div>
      </div>

      <div class="actions no-print">
        <button type="button" class="btn btn-secondary" id="copyQuoteLinkBtn">Copy quote link</button>
        <a class="btn btn-secondary" href="{{ request.path }}" target="_blank" rel="noopener">Open quote link</a>
        <a class="btn btn-secondary" href="/quote/{{ quote_public_key or quote.quote_token }}/pdf" target="_blank" rel="noopener">Download PDF</a>
        <button type="button" class="btn btn-secondary" onclick="window.print()">Print</button>
        {% if quote.status == 'approved' %}
          <a class="btn btn-secondary" href="/convert_invoice/{{ quote.quote_token }}">Convert to Invoice</a>
        {% endif %}
      </div>
      <div class="hero-help">Send this live quote link by text or email. Customers will see the selected service pricing update instantly as they choose parts options.</div>
    </div>

    {% if inspection and inspection["items"] %}
    <div class="card">
      <div class="section-head">
        <div>
          <h2>Inspection Notes</h2>
          <div class="muted" style="margin-top:6px;">Captured during estimate build.</div>
        </div>
      </div>
      {% for item in inspection["items"] %}
      <div class="inspection-item">
        <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
          <strong>{{ item.label or 'Inspection Item' }}</strong>
          <span class="inspection-status status-{{ item.status }}">{{ item.status.replace('_', ' ') }}</span>
        </div>
        {% if item.notes %}
          <div class="muted" style="margin-top:8px;white-space:pre-wrap;">{{ item.notes }}</div>
        {% endif %}
        {% if item.photo %}
          <div style="margin-top:10px;"><img src="{{ item.photo }}" alt="Inspection photo" style="max-width:100%;border-radius:12px;border:1px solid var(--line);"></div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {% if quote.status == 'approved' or quote.status == 'invoiced' %}
    <div class="card">
      <h2>Estimate Approved</h2>
      <span class="pill approved-pill">Signed / Approved</span>
      <div class="meta" style="margin-top:12px;">
        <div><strong>Signed By</strong><br>{{ quote.signed_name or 'Customer' }}</div>
        <div><strong>Signed At</strong><br>{{ quote.signed_at or '-' }}</div>
      </div>
    </div>
    {% endif %}

    {% set tax_rate = quote.tax_rate|default(0)|float %}
    {% set service_fee = quote.service_fee|default(0)|float %}
    {% set labor_rate = quote.labor_rate|default(0)|float %}

    <form method="POST" action="/approve_quote/{{ quote.quote_token }}" id="quoteForm">
      <div class="card">
        <div class="section-head">
          <div>
            <h2>Services</h2>
            <div class="muted" style="margin-top:6px;">Each service shows labor, parts choices, and your running total clearly.</div>
          </div>
          {% if quote.status == 'approved' or quote.status == 'invoiced' %}
            <span class="pill approved-pill">Selections locked</span>
          {% else %}
            <span class="pill">Choose only what you want approved</span>
          {% endif %}
        </div>

        {% if jobs and jobs|length > 0 %}
          {% for job in jobs %}
            {% set job_index = loop.index0 %}
            {% set desc = job.get('desc') or 'Service Item' %}
            {% set notes = job.get('notes') or '' %}
            {% set labor_hours = job.get('labor_hours', 0)|float %}
            {% set labor_total = labor_hours * labor_rate %}
            {% set parts = job.get('parts', []) %}
            {% set approved_item = approved_map.get(job_index, {}) if approved_map is defined else {} %}
            {% set selected_parts = approved_item.get('selected_parts', []) %}
            <div class="service-card job" data-job-index="{{ job_index }}" data-labor-total="{{ '%.2f'|format(labor_total) }}">
              <div class="service-shell">
                <div class="service-top">
                  <div>
                    <div class="service-title">{{ desc }}</div>
                    <div class="service-sub">{{ '%.2f'|format(labor_hours) }} hr labor • ${{ '%.2f'|format(labor_rate) }}/hr</div>
                  </div>
                  <div class="service-money job-total-display">$0.00</div>
                </div>

                <div class="service-controls">
                  <button type="button" class="mini-btn active" data-toggle="details">Details</button>
                  <button type="button" class="mini-btn {% if not notes %}disabled-btn{% endif %}" data-toggle="notes">Notes</button>
                </div>

                <div class="section-block open" data-section="details">
                  <div class="detail-grid">
                    <div class="detail-box">
                      <div class="k">Labor Hours</div>
                      <div class="v">{{ '%.2f'|format(labor_hours) }}</div>
                    </div>
                    <div class="detail-box">
                      <div class="k">Labor Rate</div>
                      <div class="v">${{ '%.2f'|format(labor_rate) }}/hr</div>
                    </div>
                    <div class="detail-box">
                      <div class="k">Labor Total</div>
                      <div class="v">${{ '%.2f'|format(labor_total) }}</div>
                    </div>
                  </div>

                  {% if parts and parts|length > 0 %}
                  <div class="parts-box">
                    <div class="help">Parts are listed by name, selected option, and customer price. Pick the option you want for each part line.</div>

                    {% for part in parts %}
                      {% set part_index = loop.index0 %}
                      {% set qty = part.get('qty', 1)|float %}
                      {% set enabled = [] %}
                      {% if part.get('enabled_oem', part.get('oem', 0)|float > 0) %}{% set _ = enabled.append('oem') %}{% endif %}
                      {% if part.get('enabled_quality', part.get('quality', 0)|float > 0 or not enabled) %}{% set _ = enabled.append('quality') %}{% endif %}
                      {% if part.get('enabled_economy', part.get('economy', 0)|float > 0) %}{% set _ = enabled.append('economy') %}{% endif %}
                      {% if enabled|length == 0 %}{% set _ = enabled.append('quality') %}{% endif %}
                      {% set chosen = namespace(tier=part.get('selected_tier', 'quality')) %}
                      {% if chosen.tier not in enabled %}
                        {% if 'quality' in enabled %}{% set chosen.tier = 'quality' %}{% else %}{% set chosen.tier = enabled[0] %}{% endif %}
                      {% endif %}
                      {% for saved_part in selected_parts %}
                        {% if saved_part.get('part_index') == part_index and saved_part.get('tier') in enabled %}
                          {% set chosen.tier = saved_part.get('tier') %}
                        {% endif %}
                      {% endfor %}
                      {% set chosen_price = part.get(chosen.tier, 0)|float %}
                      <div class="part-row" data-part-row>
                        <div class="part-head">
                          <div class="part-name">{{ part.get('part_desc') or 'Part' }}</div>
                          <span class="qty-badge">Qty {{ '%.2f'|format(qty) }}</span>
                        </div>

                        <div class="selected-summary">
                          <div>
                            <div class="label">Selected option</div>
                            <div class="value current-choice-label">{{ chosen.tier|upper }}</div>
                          </div>
                          <div style="text-align:right;">
                            <div class="label">Customer price</div>
                            <div class="price current-choice-price">${{ '%.2f'|format(chosen_price * qty) }}</div>
                          </div>
                        </div>

                        {% if quote.status == 'approved' or quote.status == 'invoiced' or enabled|length == 1 %}
                          {% set locked_tier = chosen.tier if enabled|length > 1 else enabled[0] %}
                          <input type="hidden" name="part_tier_{{ job_index }}_{{ part_index }}" value="{{ locked_tier }}">
                          <div class="locked-choice">
                            <div>
                              <div class="muted" style="font-size:12px;">Selected option</div>
                              <div class="locked-tier">{{ locked_tier|upper }}</div>
                            </div>
                            <div style="text-align:right;">
                              <div class="muted" style="font-size:12px;">Customer price</div>
                              <div class="locked-price">
                                ${{ '%.2f'|format((part.get(locked_tier, 0)|float) * qty) }}
                              </div>
                            </div>
                          </div>
                        {% else %}
                          <div class="choices-grid">
                            {% for tier in enabled %}
                              {% set tier_price = (part.get(tier, 0)|float) * qty %}
                              <label class="choice-card {% if chosen.tier == tier %}selected{% endif %}">
                                <input
                                  class="part-line-choice"
                                  type="radio"
                                  name="part_tier_{{ job_index }}_{{ part_index }}"
                                  value="{{ tier }}"
                                  {% if chosen.tier == tier %}checked{% endif %}
                                >
                                <div class="choice-top">
                                  <div class="choice-name">{{ tier|upper }}</div>
                                  <span class="choice-tag">Option</span>
                                </div>
                                <div class="choice-price">${{ '%.2f'|format(tier_price) }}</div>
                                <div class="choice-note">{{ part.get('part_desc') or 'Part' }} • Qty {{ '%.2f'|format(qty) }}</div>
                                <div class="choice-row">
                                  <span class="mini">Customer total for this line</span>
                                  <strong>${{ '%.2f'|format(tier_price) }}</strong>
                                </div>
                              </label>
                            {% endfor %}
                          </div>
                        {% endif %}

                        <div
                          class="part-price"
                          data-price-oem="{{ '%.2f'|format((part.get('oem', 0)|float) * qty) }}"
                          data-price-quality="{{ '%.2f'|format((part.get('quality', 0)|float) * qty) }}"
                          data-price-economy="{{ '%.2f'|format((part.get('economy', 0)|float) * qty) }}">
                        </div>
                      </div>
                    {% endfor %}
                  </div>
                  {% endif %}

                  {% if quote.status != 'approved' and quote.status != 'invoiced' %}
                  <div class="approve-row">
                    <input type="checkbox" class="approve-job" name="approve_job[]" value="{{ job_index }}" checked>
                    <div class="approve-text">
                      <strong>Approve this service</strong>
                      <span class="muted">Uncheck this if you do not want to approve this service right now.</span>
                    </div>
                  </div>
                  {% else %}
                  <div class="approve-row">
                    <span class="pill approved-pill">Approved service</span>
                  </div>
                  {% endif %}
                </div>

                {% if notes %}
                <div class="section-block" data-section="notes">
                  <div class="detail-box" style="margin-top:10px;">
                    <div class="k">Notes</div>
                    <div class="muted" style="margin-top:8px;white-space:pre-wrap;">{{ notes }}</div>
                  </div>
                </div>
                {% endif %}
              </div>
            </div>
          {% endfor %}

          <div class="summary-shell" style="margin-top:18px;">
            <div class="summary-note">
              {% if quote.status == 'approved' or quote.status == 'invoiced' %}
                <h4>Estimate status</h4>
                <div class="muted" style="margin-top:8px;">This quote has already been approved, so service selections and parts choices are now locked in.</div>
              {% else %}
                <h4>Before you approve</h4>
                <div class="muted" style="margin-top:8px;">Review the services you want, confirm you have permission for mobile service at the vehicle location, then sign to approve.</div>
              {% endif %}
            </div>

            <div class="summary">
              <div class="summary-row"><span>Labor</span><strong>$<span id="summaryLabor">0.00</span></strong></div>
              <div class="summary-row"><span>Parts</span><strong>$<span id="summaryParts">0.00</span></strong></div>
              <div class="summary-row"><span>Tax</span><strong>$<span id="summaryTax">0.00</span></strong></div>
              <div class="summary-row"><span>Service Call Fee</span><strong>${{ '%.2f'|format(service_fee) }}</strong></div>
              <div class="summary-row total"><span>Total</span><strong>$<span id="summaryGrandTotal">0.00</span></strong></div>
            </div>
          </div>

        {% else %}
          <div class="empty">No services found on this quote.</div>
        {% endif %}
      </div>

      {% if quote.status != 'approved' and quote.status != 'invoiced' and jobs and jobs|length > 0 %}
      <div class="card">
        <h2>Approval</h2>

        <div style="display:flex;gap:10px;align-items:flex-start;background:var(--panel-3);border:1px solid var(--line);border-radius:12px;padding:12px;">
          <input type="checkbox" id="location_permission_confirm" name="location_permission_confirm" value="yes" style="width:18px;height:18px;margin-top:2px;flex:0 0 auto;">
          <label for="location_permission_confirm" style="margin:0;cursor:pointer;"><strong>I confirm I have permission for on-site mobile service at this vehicle location.</strong></label>
        </div>

        <label for="signed_name" style="margin-top:16px;display:block;"><strong>Printed Name</strong></label>
        <div style="margin-top:8px;"><input type="text" id="signed_name" name="signed_name" placeholder="Enter your name"></div>

        <div class="signature-wrap">
          <strong>Signature</strong>
          <div class="muted">Sign below to approve the selected services and selected parts option.</div>
          <div class="signature-pad-wrap"><canvas id="signaturePad"></canvas></div>
          <input type="hidden" name="signature_data" id="signature_data">
          <div class="actions">
            <button type="button" class="btn btn-secondary" id="clearSignature">Clear Signature</button>
            <button type="submit" class="btn btn-primary">Approve Selected Services</button>
          </div>
        </div>
      </div>
      {% endif %}
    </form>
  </div>

  <script>
    (function(){
      const taxRate = {{ tax_rate|tojson }};
      const serviceFee = {{ service_fee|tojson }};
      const jobs = Array.from(document.querySelectorAll('.job'));

      function money(n){ return Number(n || 0).toFixed(2); }

      function isApproved(jobEl){
        const cb = jobEl.querySelector('.approve-job');
        return cb ? cb.checked : true;
      }

      function getSelectedTier(row){
        const selectedRadio = row.querySelector('.part-line-choice:checked');
        const hiddenTier = row.querySelector('input[type="hidden"][name^="part_tier_"]');
        return ((selectedRadio ? selectedRadio.value : (hiddenTier ? hiddenTier.value : 'quality')) || 'quality').toLowerCase();
      }

      function getSelectedPartsTotal(jobEl){
        const primaryPartsBox = jobEl.querySelector('.parts-box');
        const rows = primaryPartsBox ? Array.from(primaryPartsBox.querySelectorAll('[data-part-row]')) : [];
        return rows.reduce((sum,row)=>{
          const tier = getSelectedTier(row);
          const priceEl = row.querySelector('.part-price');
          return sum + Number(priceEl?.getAttribute(`data-price-${tier}`) || 0);
        },0);
      }

      function updateChoiceCards(scope){
        (scope || document).querySelectorAll('[data-part-row]').forEach(row=>{
          const selectedTier = getSelectedTier(row);
          row.querySelectorAll('.choice-card').forEach(card=>{
            const input = card.querySelector('.part-line-choice');
            card.classList.toggle('selected', !!(input && input.checked));
          });
          const priceEl = row.querySelector('.part-price');
          const currentChoiceLabel = row.querySelector('.current-choice-label');
          const currentChoicePrice = row.querySelector('.current-choice-price');
          const linePrice = Number(priceEl?.getAttribute(`data-price-${selectedTier}`) || 0);
          if(currentChoiceLabel) currentChoiceLabel.textContent = selectedTier.toUpperCase();
          if(currentChoicePrice) currentChoicePrice.textContent = '$' + money(linePrice);
        });
      }

      function updateJob(jobEl){
        const labor = Number(jobEl.dataset.laborTotal || 0);
        const parts = getSelectedPartsTotal(jobEl);
        const active = isApproved(jobEl);
        const effectiveLabor = active ? labor : 0;
        const effectiveParts = active ? parts : 0;
        const total = effectiveLabor + effectiveParts;
        const display = jobEl.querySelector('.job-total-display');
        if(display) display.textContent = '$' + money(total);
        return {labor:effectiveLabor, parts:effectiveParts};
      }

      function updateSummary(){
        let labor = 0, parts = 0;
        jobs.forEach(job=>{
          const vals = updateJob(job);
          labor += vals.labor;
          parts += vals.parts;
        });
        const tax = parts * (Number(taxRate || 0) / 100);
        const grand = labor + parts + tax + Number(serviceFee || 0);
        const summaryLabor = document.getElementById('summaryLabor');
        const summaryParts = document.getElementById('summaryParts');
        const summaryTax = document.getElementById('summaryTax');
        const summaryGrand = document.getElementById('summaryGrandTotal');
        if(summaryLabor) summaryLabor.textContent = money(labor);
        if(summaryParts) summaryParts.textContent = money(parts);
        if(summaryTax) summaryTax.textContent = money(tax);
        if(summaryGrand) summaryGrand.textContent = money(grand);
      }

      jobs.forEach(job=>{
        job.querySelectorAll('.approve-job, .part-line-choice').forEach(el=>{
          el.addEventListener('change', ()=>{
            updateChoiceCards(job);
            updateSummary();
          });
        });

        const detailBtn = job.querySelector('[data-toggle="details"]');
        const notesBtn = job.querySelector('[data-toggle="notes"]');
        const detailsSection = job.querySelector('[data-section="details"]');
        const notesSection = job.querySelector('[data-section="notes"]');

        if(detailBtn && detailsSection){
          detailBtn.addEventListener('click', ()=>{
            detailsSection.classList.toggle('open');
            detailBtn.classList.toggle('active');
          });
        }
        if(notesBtn && notesSection && !notesBtn.classList.contains('disabled-btn')){
          notesBtn.addEventListener('click', ()=>{
            notesSection.classList.toggle('open');
            notesBtn.classList.toggle('active');
          });
        }
      });

      updateChoiceCards();
      updateSummary();

      const copyQuoteLinkBtn = document.getElementById('copyQuoteLinkBtn');
      if(copyQuoteLinkBtn){
        copyQuoteLinkBtn.addEventListener('click', async ()=>{
          const link = window.location.href;
          try{
            await navigator.clipboard.writeText(link);
            copyQuoteLinkBtn.textContent = 'Link copied';
            setTimeout(()=>{ copyQuoteLinkBtn.textContent = 'Copy quote link'; }, 1800);
          }catch(_err){
            window.prompt('Copy this quote link:', link);
          }
        });
      }

      const canvas = document.getElementById('signaturePad');
      const hiddenInput = document.getElementById('signature_data');
      const clearBtn = document.getElementById('clearSignature');

      if(canvas && hiddenInput){
        const ctx = canvas.getContext('2d');
        let drawing = false, hasSigned = false;

        function resizeCanvas(){
          const ratio = Math.max(window.devicePixelRatio || 1, 1);
          const rect = canvas.getBoundingClientRect();
          canvas.width = rect.width * ratio;
          canvas.height = rect.height * ratio;
          ctx.setTransform(1,0,0,1,0,0);
          ctx.scale(ratio,ratio);
          ctx.lineWidth = 2;
          ctx.lineCap = 'round';
          ctx.strokeStyle = '#111';
          ctx.fillStyle = '#fff';
          ctx.fillRect(0,0,rect.width,rect.height);
          hasSigned = false;
          hiddenInput.value = '';
        }

        function getPos(e){
          const rect = canvas.getBoundingClientRect();
          if(e.touches && e.touches.length){
            return {x:e.touches[0].clientX-rect.left,y:e.touches[0].clientY-rect.top};
          }
          return {x:e.clientX-rect.left,y:e.clientY-rect.top};
        }

        function startDraw(e){
          drawing = true;
          hasSigned = true;
          const pos = getPos(e);
          ctx.beginPath();
          ctx.moveTo(pos.x,pos.y);
          e.preventDefault();
        }

        function draw(e){
          if(!drawing) return;
          const pos = getPos(e);
          ctx.lineTo(pos.x,pos.y);
          ctx.stroke();
          e.preventDefault();
        }

        function endDraw(){
          drawing = false;
          if(hasSigned) hiddenInput.value = canvas.toDataURL('image/png');
        }

        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);
        canvas.addEventListener('mousedown', startDraw);
        canvas.addEventListener('mousemove', draw);
        canvas.addEventListener('mouseup', endDraw);
        canvas.addEventListener('mouseleave', endDraw);
        canvas.addEventListener('touchstart', startDraw, {passive:false});
        canvas.addEventListener('touchmove', draw, {passive:false});
        canvas.addEventListener('touchend', endDraw);
        if(clearBtn) clearBtn.addEventListener('click', ()=>resizeCanvas());
      }

      const form = document.getElementById('quoteForm');
      if(form){
        form.addEventListener('submit', function(e){
          const approvals = Array.from(document.querySelectorAll('.approve-job'));
          const approvedAny = approvals.some(cb=>cb.checked);
          const signedName = document.getElementById('signed_name');
          const signatureData = document.getElementById('signature_data');
          const locationPermissionConfirm = document.getElementById('location_permission_confirm');

          if(approvals.length && !approvedAny){
            e.preventDefault();
            alert('Please approve at least one service before submitting.');
            return;
          }
          if(locationPermissionConfirm && !locationPermissionConfirm.checked){
            e.preventDefault();
            alert('Please confirm you have permission for on-site mobile service before approving.');
            return;
          }
          if(signedName && !signedName.value.trim()){
            e.preventDefault();
            alert('Please enter your name before approving.');
            return;
          }
          if(signatureData && !signatureData.value){
            e.preventDefault();
            alert('Please sign before approving.');
          }
        });
      }
    })();
  </script>
</body>
</html>
